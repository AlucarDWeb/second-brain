# macOS
.DS_Store

# Obsidian — local UI state & cache (shared config app.json/appearance.json/core-plugins.json IS committed)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/app.json
